# LLM Provider Configuration (for drafting agents — the main agent_node call)
DRAFT_LLM_PROVIDER=openai  # Options: openai, anthropic, gemini
DRAFT_LLM_MODEL=gpt-5.4    # Default drafting model (OpenAI flagship). Per-request override via CreateDraftJobRequest.model.

# Translation + Chat model defaults
# OCR_CACHE_ENABLED=true           # Shared S3 cache for OCR AND scanned-PDF vision translation. false = always call LLM per page.
CHAT_LLM_MODEL=gemini-2.5-flash  # Default model for workspace chat and summary/synopsis.
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key
SARVAM_API_KEY=your-sarvam-api-key
# Sarvam REST /translate: parallel segments + retries (raise concurrency only if quota allows)
SARVAM_TRANSLATE_MAX_CONCURRENCY=2
SARVAM_TRANSLATE_MAX_RETRIES=6
SARVAM_TRANSLATE_RETRY_BASE_SECONDS=1

# OCR backend: "gemini", "mistral", "mistral_ocr", or "sarvam"
OCR_PROVIDER=gemini
MISTRAL_OCR_MODEL=mistral-ocr-latest
# Azure Document Intelligence (translation_v3 stage 2 OCR — prebuilt-layout).
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-azure-doc-intel-key
# Scanned-PDF translation: vision LLM reconstructs translated HTML/PDF from page images.
VISION_TRANSLATION_MODEL=claude-sonnet-4-5-20250929
VISION_TRANSLATION_CONCURRENCY=4
# Parallel Sarvam jobs when chunking long PDFs (each chunk is ≤10 pages)
SARVAM_OCR_CONCURRENCY=4
# Sarvam language hint. "unknown" lets Sarvam auto-detect; override to e.g. "hi-IN", "ta-IN"
SARVAM_OCR_LANGUAGE=unknown
# Sarvam chat/translation model: sarvam-m (24B, default), sarvam-30b, sarvam-105b
SARVAM_CHAT_MODEL=sarvam-m
# Sarvam OpenAI-compatible base URL (override only if Sarvam changes hosts)
SARVAM_API_BASE_URL=https://api.sarvam.ai/v1
# S3-backed OCR cache (content-hashed). Disable for debugging.
OCR_CACHE_ENABLED=true
OCR_CACHE_PREFIX=ocr-cache

# Service Configuration
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8001
DEBUG=false

# Job Configuration
JOB_TIMEOUT_SECONDS=1800
JOB_MAX_RETRIES=3

# ── Workspace RAG (in-process) ───────────────────────────────────────────────
# Collections API is mounted on this service at /api/v1/collections/* (see rag_engine/).

# Qdrant vector store
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=          # leave empty for local; set for Qdrant Cloud
QDRANT_TIMEOUT=30

# Embedding model
# Options:
#   openai + text-embedding-3-small (1536 dims) — recommended for cost + multilingual incl. Indic
#   openai + text-embedding-3-large (3072 dims) — higher quality, more expensive
#   gemini + gemini-embedding-2-preview (3072 dims)
# Switching providers/models requires reindexing — vectors are not compatible across models
# even when dimensions match.
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_SIZE=1536           # Must match the embedding model output dimension
DISTANCE_METRIC=COSINE

# RAG LLM (for query answering inside RAG)
# Note: RAG-engine reuses DRAFT_LLM_PROVIDER (set above) — there is no
# separate RAG_LLM_PROVIDER env var today. The OPENAI_MODEL / GEMINI_MODEL
# below are provider-specific defaults the RAG client picks up.
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.5-flash

# Translation backend.
#   sarvam                       — Sarvam REST formal translate (default)
#   gemini-2.5-flash             — Gemini via langchain
#   claude-haiku-4-5-20251001    — Claude via langchain
#   gpt-5-mini                   — OpenAI via langchain
# For Hindi target, LLM models automatically apply the CBIC/Rajbhasha legal prompt.
TRANSLATION_LLM_MODEL=sarvam

# Reranker (cross-encoder reranking of retrieved chunks)
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=5

# Chunking / relevance settings
CHUNK_SIZE=800
CHUNK_OVERLAP=100
RELEVANCE_THRESHOLD=0.4

# Serper web search (for workspace chat web search tool)
SERPER_API_KEY=
