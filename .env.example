# LLM Provider Configuration
LLM_PROVIDER=openai  # Options: openai, anthropic, gemini
LLM_MODEL=gpt-4o  # Model name
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key

# Service Configuration
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8001
DEBUG=false

# Job Configuration
JOB_TIMEOUT_SECONDS=300
JOB_MAX_RETRIES=3

# ── RAG Engine ────────────────────────────────────────────────────────────────
# In-process RAG loads the full stack (parsers, Qdrant, embeddings). On low-RAM
# hosts (e.g. Render 512MB) set RAG_IN_PROCESS=false and RAG_ENGINE_BASE_URL to a
# separate service that exposes /api/v1/collections/* (same codebase, larger plan).
RAG_IN_PROCESS=true
RAG_ENGINE_BASE_URL=http://localhost:8000

# Qdrant vector store
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=          # leave empty for local; set for Qdrant Cloud
QDRANT_TIMEOUT=30

# Embedding model
EMBEDDING_PROVIDER=gemini  # Options: gemini, openai, huggingface
EMBEDDING_MODEL=gemini-embedding-2-preview
VECTOR_SIZE=1536           # Must match the embedding model output dimension
DISTANCE_METRIC=COSINE

# RAG LLM (for query answering inside RAG; can differ from drafting LLM)
LLM_PROVIDER=openai        # Options: openai, gemini
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.0-flash

# Reranker (cross-encoder reranking of retrieved chunks)
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=5

# Critic (optional Gemini-based answer quality evaluation)
CRITIC_ENABLED=false
CRITIC_MODEL_NAME=models/gemini-2.5-flash
CRITIC_MODEL_API_KEY=      # separate key for critic if needed

# LlamaCloud / LlamaParse (optional; for advanced PDF parsing)
LLAMA_CLOUD_API_KEY=

# Chunking / relevance settings
CHUNK_SIZE=800
CHUNK_OVERLAP=100
RELEVANCE_THRESHOLD=0.4

# Serper web search (for workspace chat web search tool)
SERPER_API_KEY=
